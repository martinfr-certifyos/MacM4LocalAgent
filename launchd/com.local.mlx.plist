<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>          <string>com.local.mlx</string>
  <key>RunAtLoad</key>      <true/>
  <key>KeepAlive</key>      <true/>
  <key>ProcessType</key>    <string>Interactive</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>   <string>@@REPO_ROOT@@/.venvs/mlx/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>   <string>@@HOME@@</string>
    <key>USER</key>   <string>@@USER@@</string>
    <key>TMPDIR</key> <string>@@TMPDIR@@</string>
  </dict>
  <!-- See com.local.ollama.plist: logs are redirected by the child shell
       because launchd cannot open files under ~/Documents (TCC). -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>cd "@@REPO_ROOT@@" &amp;&amp; exec "@@REPO_ROOT@@/.venvs/mlx/bin/python" -m mlx_lm server --model "@@MLX_LOCAL_DIR@@" --host 127.0.0.1 --port 8081 &gt;&gt; "@@REPO_ROOT@@/.logs/mlx.out.log" 2&gt;&gt; "@@REPO_ROOT@@/.logs/mlx.err.log"</string>
  </array>
</dict>
</plist>
