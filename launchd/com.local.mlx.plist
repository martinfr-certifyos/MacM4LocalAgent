<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>          <string>com.local.mlx</string>
  <key>RunAtLoad</key>      <true/>
  <key>KeepAlive</key>      <true/>
  <key>WorkingDirectory</key><string>@@REPO_ROOT@@</string>
  <key>ProcessType</key>    <string>Interactive</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>   <string>@@REPO_ROOT@@/.venvs/mlx/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>   <string>@@HOME@@</string>
    <key>USER</key>   <string>@@USER@@</string>
    <key>TMPDIR</key> <string>@@TMPDIR@@</string>
  </dict>
  <key>ProgramArguments</key>
  <array>
    <string>@@REPO_ROOT@@/.venvs/mlx/bin/python</string>
    <string>-m</string><string>mlx_lm</string>
    <string>server</string>
    <string>--model</string><string>@@MLX_LOCAL_DIR@@</string>
    <string>--host</string><string>127.0.0.1</string>
    <string>--port</string><string>8081</string>
  </array>
  <key>StandardOutPath</key><string>@@REPO_ROOT@@/.logs/mlx.out.log</string>
  <key>StandardErrorPath</key><string>@@REPO_ROOT@@/.logs/mlx.err.log</string>
</dict>
</plist>
