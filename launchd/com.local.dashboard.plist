<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>          <string>com.local.dashboard</string>
  <key>RunAtLoad</key>      <true/>
  <key>KeepAlive</key>      <true/>
  <key>WorkingDirectory</key><string>@@REPO_ROOT@@</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>      <string>@@REPO_ROOT@@/.venvs/litellm/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>PYTHONPATH</key><string>@@REPO_ROOT@@</string>
  </dict>
  <key>ProgramArguments</key>
  <array>
    <string>@@REPO_ROOT@@/.venvs/litellm/bin/python</string>
    <string>-m</string><string>uvicorn</string>
    <string>dashboard.app:app</string>
    <string>--host</string><string>127.0.0.1</string>
    <string>--port</string><string>4001</string>
  </array>
  <key>StandardOutPath</key><string>@@REPO_ROOT@@/.logs/dashboard.out.log</string>
  <key>StandardErrorPath</key><string>@@REPO_ROOT@@/.logs/dashboard.err.log</string>
</dict>
</plist>
